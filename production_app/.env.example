# ===========================================================
# AI Expression Analyzer - Production Environment Variables
# ===========================================================

# ============= SERVER CONFIGURATION =============
HOST=0.0.0.0
PORT=8005
WORKERS=4
DEBUG=False
LOG_LEVEL=info

# ============= CORS CONFIGURATION =============
# Comma-separated list of allowed origins
CORS_ORIGINS=*
# Production example: https://example.com,https://app.example.com

# ============= DEVICE CONFIGURATION =============
# Options: auto, cuda, cpu, mps
DEVICE_TYPE=auto

# ============= MODEL PATHS =============
EMOTION_MODEL_PATH=./models/best_model_dcnn_dam.pth
YOLO_MODEL=yolov8n.pt
AGE_MODEL=nateraw/vit-age-classifier

# ============= PERFORMANCE =============
MAX_UPLOAD_SIZE=10485760
REQUEST_TIMEOUT=30

# ============= DATABASE (if needed) =============
# DATABASE_URL=postgresql://user:password@localhost/emotion_engine

# ============= LOGGING =============
LOG_FILE=/var/log/emotion-engine/app.log
LOG_LEVEL=info

# ============= SENTRY (Error Tracking - Optional) =============
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
